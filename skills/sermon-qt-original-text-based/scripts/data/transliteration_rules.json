  "greek_forbidden_patterns": [
    {
      "pattern": "η→이",
      "violation_example": "ζωή→조이",
      "correction": "ζωή→조에",
      "reason": "modern Greek 발음. Erasmian은 'η'를 '에'로 표기."
    },
    {
      "pattern": "θ→쓰",
      "violation_example": "θεός→쎄오스",
      "correction": "θεός→테오스",
      "reason": "modern Greek 발음. Erasmian은 'θ'를 'ㅌ'(거센)로 표기."
    },
    {
      "pattern": "ου→오우",
      "violation_example": "λόγου→로고우",
      "correction": "λόγου→로구",
      "reason": "이중모음 ου의 표준은 '우'. '오우'는 영어식 표기."
    },
    {
      "pattern": "υ→이 (단독)",
      "violation_example": "κύριος→키리오스",
      "correction": "κύριος→퀴리오스",
      "reason": "단독 υ는 '위'. '이'는 modern Greek."
    },
    {
      "pattern": "χ→차/치",
      "violation_example": "χάρις→차리스",
      "correction": "χάρις→카리스",
      "reason": "χ는 강한 ㅋ. '차/치'는 영어식 ch 표기 혼동."
    },
    {
      "pattern": "거친 숨표 누락",
      "violation_example": "ὁ→오, αἷμα→아이마",
      "correction": "ὁ→호, αἷμα→하이마",
      "reason": "거친 숨표( ̔)는 'ㅎ' 첨가."
    }
  ],
